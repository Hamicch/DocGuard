graph TB
    subgraph Developer["👤 Developer"]
        DEV[Engineer]
    end

    subgraph GitHub["🐙 GitHub"]
        REPO[Target Repo<br/>Python code + Markdown docs]
        PR[Pull Request]
        WEBHOOK[Webhook<br/>pull_request opened/sync]
        GH_API[GitHub REST API<br/>diffs, files, comments]
        GH_APP[GitHub App<br/>installed on repo]
    end

    subgraph Frontend["🎨 Dashboard - Next.js on Vercel"]
        LOGIN[Login Page<br/>Supabase Auth UI]
        RUNS[Runs List View<br/>past PR audits]
        DETAIL[Finding Detail View<br/>━━━━━━━━━━━━━━<br/>• Current code<br/>• Current doc<br/>• Proposed fix<br/>• Reasoning<br/>• Accept/Ignore/Custom]
    end

    subgraph Supabase["☁️ Supabase"]
        AUTH[Supabase Auth<br/>━━━━━━━━━━━━━━<br/>• Email/password<br/>• Magic link<br/>• Google/GitHub OAuth<br/>• JWT issuance]
        SB_DB[(Supabase Postgres<br/>━━━━━━━━━━━━━━<br/>• repos<br/>• audit_runs<br/>• findings)]
    end

    subgraph AWS["☁️ AWS - Terraform Provisioned"]
        direction TB

        subgraph Network["Networking"]
            APIGW[API Gateway HTTP API<br/>HTTPS routes]
        end

        subgraph Compute["AWS Lambda"]
            LAMBDA[FastAPI on Lambda<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>POST /webhooks/github<br/>GET /api/runs<br/>GET /api/runs/&#123;id&#125;<br/>POST /api/findings/&#123;id&#125;/action<br/>GET /api/repos<br/>POST /api/repos<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>Mangum or Lambda Web Adapter<br/>• domain/<br/>• services/<br/>• adapters/<br/>• repositories/<br/>• api/]
        end

        subgraph Internals["⚙️ Agent Components"]
            direction TB
            AST_INDEX[Python AST Indexer<br/>extract symbols]
            MD_INDEX[Markdown Indexer<br/>extract refs + code blocks]
            LINKER[Doc-Code Linker<br/>match docs to symbols]
            CONV_EXTRACT[Convention Extractor<br/>infer style from existing code]
            DIFF_ANALYZER[PR Diff Analyzer<br/>identify changes]

            JUDGE[Drift Judge LLM<br/>Pydantic structured output]
            STYLE_JUDGE[Style Judge LLM<br/>convention violations]
            DRAFTER[Fix Drafter LLM<br/>proposed fixes]
        end

        subgraph Secrets["🔐 Lambda environment"]
            SM[━━━━━━━━━━━━━━<br/>• OpenRouter API key<br/>• GitHub App private key<br/>• Webhook secret<br/>• Supabase + DB URLs<br/>Terraform / CI-injected]
        end

        subgraph Observability["📊 CloudWatch"]
            LOGS[Structured JSON Logs<br/>━━━━━━━━━━━━━━<br/>• Run lifecycle<br/>• LLM token usage<br/>• Cost per run<br/>• Errors]
        end

        subgraph Deploy["📦 Deploy"]
            ARTIFACT[Lambda artifact<br/>zip or container image]
        end
    end

    subgraph LLM["🤖 LLM Routing"]
        OR[OpenRouter API]
        MODELS[Model Pool<br/>━━━━━━━━━━━━━━<br/>• Claude Haiku<br/>  drift judgment<br/>• GPT-4o-mini<br/>  style judgment<br/>• Gemini Flash<br/>  fallback]
    end

    subgraph DevOps["🚀 CI/CD"]
        GH_ACTIONS[GitHub Actions<br/>━━━━━━━━━━━━━━<br/>• ruff lint<br/>• mypy type check<br/>• pytest unit + integration<br/>• package / image build<br/>• terraform apply<br/>• Lambda + API Gateway deploy]
    end

    DEV -.opens PR.-> PR
    PR --> WEBHOOK
    WEBHOOK -.HTTPS POST.-> APIGW
    APIGW --> LAMBDA

    GH_APP -.installed on.-> REPO
    GH_APP -.signs webhook.-> WEBHOOK

    LAMBDA -.fetch PR diff + files.-> GH_API
    GH_API --> LAMBDA

    LAMBDA --> AST_INDEX
    LAMBDA --> MD_INDEX
    AST_INDEX --> LINKER
    MD_INDEX --> LINKER
    AST_INDEX --> CONV_EXTRACT

    LAMBDA --> DIFF_ANALYZER
    LINKER --> JUDGE
    DIFF_ANALYZER --> JUDGE
    DIFF_ANALYZER --> STYLE_JUDGE
    CONV_EXTRACT --> STYLE_JUDGE

    JUDGE -.LLM call.-> OR
    STYLE_JUDGE -.LLM call.-> OR
    DRAFTER -.LLM call.-> OR
    OR --> MODELS
    OR -.responses.-> JUDGE
    OR -.responses.-> STYLE_JUDGE
    OR -.responses.-> DRAFTER

    JUDGE --> DRAFTER
    STYLE_JUDGE --> DRAFTER

    LAMBDA -.persist runs + findings.-> SB_DB
    LAMBDA --> SM
    LAMBDA --> LOGS

    DRAFTER -.findings ready.-> LAMBDA
    LAMBDA -.post PR comment.-> GH_API
    GH_API -.comment posted.-> PR

    DEV -.signs in.-> LOGIN
    LOGIN -.OAuth.-> AUTH
    AUTH -.JWT.-> LOGIN
    LOGIN --> RUNS
    RUNS --> DETAIL

    RUNS -.GET /api/runs.-> APIGW
    DETAIL -.GET /api/runs/id.-> APIGW
    APIGW -.JWT verified.-> LAMBDA
    LAMBDA -.user-scoped query.-> SB_DB

    GH_ACTIONS -.publish.-> ARTIFACT
    ARTIFACT -.update.-> LAMBDA
    GH_ACTIONS -.terraform apply.-> AWS

    classDef devClass fill:#e1f5ff,stroke:#0288d1,color:#000
    classDef githubClass fill:#f5f5f5,stroke:#24292e,color:#000
    classDef frontendClass fill:#f3e5f5,stroke:#7b1fa2,color:#000
    classDef supabaseClass fill:#e8f5e9,stroke:#3ecf8e,color:#000
    classDef networkClass fill:#fff3e0,stroke:#f57c00,color:#000
    classDef computeClass fill:#e8f5e9,stroke:#388e3c,color:#000
    classDef internalsClass fill:#fff9c4,stroke:#f57f17,color:#000
    classDef secretsClass fill:#ffebee,stroke:#c62828,color:#000
    classDef obsClass fill:#e0f2f1,stroke:#00796b,color:#000
    classDef registryClass fill:#fffde7,stroke:#f9a825,color:#000
    classDef llmClass fill:#fce4ec,stroke:#c2185b,color:#000
    classDef devopsClass fill:#ede7f6,stroke:#512da8,color:#000

    class DEV devClass
    class REPO,PR,WEBHOOK,GH_API,GH_APP githubClass
    class LOGIN,RUNS,DETAIL frontendClass
    class AUTH,SB_DB supabaseClass
    class APIGW networkClass
    class LAMBDA computeClass
    class AST_INDEX,MD_INDEX,LINKER,CONV_EXTRACT,DIFF_ANALYZER,JUDGE,STYLE_JUDGE,DRAFTER internalsClass
    class SM secretsClass
    class LOGS obsClass
    class ARTIFACT registryClass
    class OR,MODELS llmClass
    class GH_ACTIONS devopsClass
