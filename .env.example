# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase Postgres connection string (Transaction Pooler recommended for Lambda)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ── GitHub App ────────────────────────────────────────────────────────────────
GITHUB_APP_ID=123456
# Multiline PEM — replace newlines with \n for Lambda / Terraform env vars
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── LLM Client ────────────────────────────────────────────────────────────────
# Provider-agnostic: points at OpenRouter by default (OpenAI-compatible API).
# To use OpenAI directly: set LLM_BASE_URL=https://api.openai.com/v1 and use an OpenAI key.
# To use Anthropic directly: set LLM_BASE_URL=https://api.anthropic.com/v1 and use an Anthropic key.
LLM_API_KEY=sk-or-v1-xxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
